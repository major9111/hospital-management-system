# Database
DATABASE_URL=postgresql://hospital:hospital_dev_pw@localhost:5432/hospital_db

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Auth (generate long random secrets for production — never reuse across envs)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string

# Shared across EVERY backend service (gateway, ehr-service, ai-service,
# billing-service, notification-service). With no Redis and no private
# networking on this deployment, this secret is the ONLY thing verifying
# cross-service calls are legitimate — treat it as seriously as the JWT
# secrets above, and use the exact same value everywhere.
INTERNAL_SERVICE_SECRET=replace_me_with_yet_another_long_random_string

# AI receptionist — pick a provider (Groq/DeepSeek/Gemini all have usable
# free tiers; Anthropic is pay-as-you-go from the first request). Only set
# the API key for whichever LLM_PROVIDER you choose.
LLM_PROVIDER=groq
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Telemedicine — optional. If unset, ehr-service falls back to a stub room
# URL so the booking/join flow still works end to end without an account.
DAILY_API_KEY=

# Service URLs — every service is a public Render Web Service on this
# deployment (no private networking on the free tier), so these are full
# https:// URLs in production, not internal hostnames.
EHR_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002
BILLING_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3002
