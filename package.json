{
  "name": "hospital-system",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/gateway",
    "apps/billing-service",
    "apps/notification-service",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:gateway": "npm run start:dev --workspace=apps/gateway",
    "dev:billing": "npm run start:dev --workspace=apps/billing-service",
    "dev:notifications": "npm run start:dev --workspace=apps/notification-service",
    "dev:ehr": "cd apps/ehr-service && uvicorn app.main:app --reload --port 8001",
    "dev:ai": "cd apps/ai-service && uvicorn app.main:app --reload --port 8002"
  }
}
