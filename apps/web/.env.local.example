# Public — used by the browser to call the gateway directly (e.g. login)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# Public — which hospital branch the self-registration page signs patients up to
# (a multi-branch UI would let the patient pick one instead of hardcoding this)
NEXT_PUBLIC_DEFAULT_HOSPITAL_ID=11111111-1111-1111-1111-111111111111

# Server-only — used by server components/route handlers proxying through the gateway
GATEWAY_INTERNAL_URL=http://localhost:3000

# Must match the gateway's JWT_ACCESS_SECRET exactly — used here only to
# decode roles for UI routing (middleware, sidebar), never as an
# authorization decision by itself.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
